# Signal adapter HTTP server port — point Dark Alpha's POSTBACK_URL here:
#   POSTBACK_URL=http://127.0.0.1:8765/signal
SIGNAL_RECEIVER_PORT=8765

# SQLite database path (relative to project root)
DB_PATH=data/shadow.db

# Log output directory
LOG_DIR=logs

# Config directory
CONFIG_DIR=config

# Set to "shadow" for Gate 1. Never change to "live" without Gate 2 authorization.
EXECUTION_MODE=shadow

# Kill switch sentinel file path (default is fine for most setups)
KILL_SWITCH_SENTINEL=/tmp/dark-alpha-kill

# Telegram alert channel — copy from DarkAlpha/.env
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — comma-separated chat IDs allowed to command the Phase 8 bot.
# If unset, falls back to TELEGRAM_CHAT_ID.
TELEGRAM_ADMIN_CHAT_IDS=
